    {
      "name": "Setup – Ops tokens",
      "description": "Chạy login theo role trước khi test Harvest Areas / Weighing Stations / Trips / Receipts. Tài khoản seed: Admin `{{adminEmail}}`, Owner `{{ownerEmail}}`, Driver `{{driverEmail}}` (mật khẩu trong biến collection). Test script lưu token vào adminAccessToken, ownerAccessToken, driverAccessToken. Sau **POST /trips** (có test script) sẽ có `tripId`.",
      "item": [
        {
          "name": "POST /auth/email/login (admin → adminAccessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('adminAccessToken', res.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/email/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "email", "login"]
            }
          },
          "response": []
        },
        {
          "name": "POST /auth/email/login (owner → ownerAccessToken)",
          "event": [
