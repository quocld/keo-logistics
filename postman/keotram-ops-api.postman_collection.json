    {
      "name": "Setup – Ops tokens",
      "description": "Chạy login theo role trước khi test Harvest Areas / Weighing Stations / Receipts. Test script lưu token vào collection variables adminAccessToken, ownerAccessToken, driverAccessToken.",
      "item": [
        {
          "name": "POST /auth/email/login (admin → adminAccessToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('adminAccessToken', res.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"secret\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/email/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "email", "login"]
            }
          },
          "response": []
