# Copy to .env.local (gitignored) for local prebuild/dev client builds.
# Do not commit real keys. Rotate keys if they were ever exposed.
# Google Cloud: enable Maps SDK for Android + iOS; restrict key by package/bundle + SHA-1 (Android).
# After setting the key, rebuild native binaries: `npx expo prebuild` then run ios/android, or EAS Build.
GOOGLE_MAPS_API_KEY=

# Ops API base (includes /api/v1). Example: http://localhost:3000/api/v1
# EXPO_PUBLIC_API_URL=

# Upload: presigned (POST JSON + PUT S3) when backend FILE_DRIVER=s3-presigned; multipart for local FILE_DRIVER=local.
# If unset, the app picks presigned for hosted API URLs and multipart for localhost / LAN IP (see lib/config.ts).
# Expo web + direct PUT to S3 requires bucket CORS allowing PUT from your web origin; mobile is unaffected.
# EXPO_PUBLIC_OPS_FILE_UPLOAD=presigned
